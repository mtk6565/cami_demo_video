{
  "name": "petverse-whatsapp-ad",
  "version": "1.0.0",
  "description": "Petverse WhatsApp AI booking flow — 30s ad video built with Remotion",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render PetverseWhatsAppAd out/petverse-ad-vertical.mp4",
    "build:landscape": "remotion render PetverseWhatsAppAd-Landscape out/petverse-ad-landscape.mp4",
    "build:all": "npm run build && npm run build:landscape",
    "build:gif": "remotion render PetverseWhatsAppAd out/petverse-ad.gif --image-format=png"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@remotion/tailwind": "^4.0.0",
    "@types/react": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
